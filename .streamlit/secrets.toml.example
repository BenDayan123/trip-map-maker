# Copy to secrets.toml and fill in (secrets.toml is gitignored).
# On Streamlit Community Cloud, set these in the app's Secrets dashboard instead.

GOOGLE_API_KEY = "your-gemini-api-key"
GEO_API_KEY = "your-geocoding-api-key"

# --- Optional: live usage gauges (Cloud Monitoring) ----------------------
# Leave unset to hide the gauges. Needs the Cloud Monitoring API enabled and a
# service account with roles/monitoring.viewer on the project behind your keys.
GCP_PROJECT_ID = "your-gcp-project-id"
GEMINI_DAILY_LIMIT = 50
GEO_MONTHLY_LIMIT = 10000
# Paste the whole service-account JSON between the triple quotes:
GCP_SA_JSON = """
{
  "type": "service_account",
  "project_id": "...",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  "client_email": "...@....iam.gserviceaccount.com",
  "token_uri": "https://oauth2.googleapis.com/token"
}
"""

# --- Optional: analytics log (Google Sheet) + admin page -----------------
ANALYTICS_SHEET_ID = "your-sheet-id"   # share the Sheet with the GCP_SA_JSON email
ADMIN_PASSWORD = "pick-something-strong"

# --- Optional: publish to My Maps from a hosted (headless) deploy ---------
# Capture a signed-in session locally with `python main.py --export-session`,
# then paste the whole storage_state.json between the triple quotes. Lets Cloud
# publish while signed in (no interactive login). NOTE: Google may still reject a
# session replayed from a datacenter IP.
GOOGLE_STORAGE_STATE = """
{ "cookies": [], "origins": [] }
"""
